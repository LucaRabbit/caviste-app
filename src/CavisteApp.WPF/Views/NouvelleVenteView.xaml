<UserControl x:Class="CavisteApp.WPF.Views.NouvelleVenteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="10">

        <!-- Boutons en bas -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
            HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Annuler" Command="{Binding AnnulerCommand}" Margin="0,0,8,0" MinWidth="100"/>
            
            <Button MinWidth="180" Margin="0,0,8,0"
                    Command="{Binding EnregistrerBrouillonCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Enregistrer en brouillon"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EstEdition}" Value="True">
                                <Setter Property="Content" Value="Mettre à jour le brouillon"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button Content="Valider la vente"
            Command="{Binding ValiderCommand}" MinWidth="150"
            Background="#2D7A2D" Foreground="White"/>
        </StackPanel>

        <!-- Message d'erreur -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding MessageErreur}"
                   Foreground="Red" Margin="0,10,0,0" TextWrapping="Wrap"/>

        <!-- Total -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="10" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock Text="TOTAL :" FontWeight="Bold" FontSize="16"/>
                <TextBlock Text="{Binding Total, StringFormat=C}"
                           FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Contenu principal -->
        <StackPanel>
            <TextBlock Text="{Binding Titre}" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- Client -->
            <TextBlock Text="Client"/>
            <ComboBox ItemsSource="{Binding ClientsDisponibles}"
                      SelectedItem="{Binding ClientSelectionne}"
                      DisplayMemberPath="Nom"
                      Margin="0,0,0,15"/>

            <!-- Ajout d'une ligne -->
            <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Ajouter un vin" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding VinsDisponibles}"
                                  SelectedItem="{Binding VinAAjouter}"
                                  DisplayMemberPath="Nom"
                                  Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding QuantiteAAjouter, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Ajouter" Command="{Binding AjouterLigneCommand}"/>
                    </Grid>
                    <TextBlock Margin="0,5,0,0" FontSize="11" Foreground="Gray"
                               Text="{Binding StockDisponibleVinAAjouter, StringFormat='Stock disponible : {0}'}"
                               Visibility="{Binding VinAAjouter, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Border>

            <!-- Panier -->
            <TextBlock Text="Panier" FontWeight="Bold" Margin="0,10,0,5"/>
            <DataGrid ItemsSource="{Binding Panier}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False"
                      HeadersVisibility="Column"
                      MinHeight="150">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Vin"        Binding="{Binding Vin.Nom}"     Width="*"/>
                    <DataGridTextColumn Header="Qté"        Binding="{Binding Quantite}"    Width="60"/>
                    <DataGridTextColumn Header="Prix unit." Binding="{Binding Vin.Prix, StringFormat=C}" Width="100"/>
                    <DataGridTextColumn Header="Sous-total" Binding="{Binding SousTotal, StringFormat=C}" Width="100"/>
                    <DataGridTemplateColumn Header="" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕"
                                        Command="{Binding DataContext.RetirerLigneCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </DockPanel>
</UserControl>