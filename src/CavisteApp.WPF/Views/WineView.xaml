<Page x:Class="CavisteApp.WPF.Views.WineView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Vins">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- Titre + recherche -->
            <RowDefinition/>
            <!-- Liste -->
        </Grid.RowDefinitions>

        <!-- Barre du haut -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Catalogue des vins"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>
            <TextBox Width="200"
                     Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Liste des vins -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Vins}"
                  SelectedItem="{Binding VinSelectionne}"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="White">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nom"     DisplayMemberBinding="{Binding Nom}"     Width="200"/>
                    <GridViewColumn Header="Région"  DisplayMemberBinding="{Binding Region}"  Width="120"/>
                    <GridViewColumn Header="Couleur" DisplayMemberBinding="{Binding Couleur}" Width="80"/>
                    <GridViewColumn Header="Année"   DisplayMemberBinding="{Binding Annee}"   Width="70"/>
                    <GridViewColumn Header="Prix €"  DisplayMemberBinding="{Binding Prix}"    Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>