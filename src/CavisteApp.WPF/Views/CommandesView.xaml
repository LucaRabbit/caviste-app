<UserControl x:Class="CavisteApp.WPF.Views.CommandesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CavisteApp.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel >

        <!--Barre d'actions -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Nouvelle commande" Command="{Binding NouvelleCommandeCommand}" Margin="0,0,8,0"/>
                <Button Content="Recharger" Command="{Binding ChargerCommand}" Margin="0,0,15,0"/>

                <TextBlock Text="Filtre :" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding StatutsDisponibles}"
                      SelectedItem="{Binding FiltreStatut}"
                      MinWidth="120" Margin="0,0,5,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource StatutDisplay}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="✕" ToolTip="Effacer le filtre"
                    Command="{Binding EffacerFiltreCommand}" Margin="0,0,15,0" Padding="6,2"/>

                <Button Content="Modifier brouillon" Command="{Binding ModifierBrouillonCommand}" Margin="0,0,8,0"/>
                <Button Content="Valider" Command="{Binding ValiderBrouillonCommand}" Margin="0,0,8,0"/>
                <Button Content="Réceptionner" Command="{Binding ReceptionnerCommand}" Margin="0,0,8,0"
                    Background="#2D7A2D" Foreground="White"/>
                <Button Content="Annuler" Command="{Binding AnnulerCommandeCommand}" Margin="0,0,8,0"/>
                <Button Content="Supprimer" Command="{Binding SupprimerBrouillonCommand}"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" Text="{Binding MessageErreur}"
                   Foreground="Red" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <!-- Liste + détails -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*" MinHeight="200"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Commandes}"
                      SelectedItem="{Binding CommandeSelectionnee}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N°"          Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Date de creation"        Binding="{Binding DateCreation, StringFormat='dd/MM/yyyy'}" Width="100"/>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding FournisseurNom}" Width="*"/>
                        <DataGridTextColumn Header="Lignes"      Binding="{Binding NombreLignes}" Width="70"/>
                        <DataGridTextColumn Header="Statut"      Binding="{Binding Statut}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="#DDD" ResizeDirection="Rows"/>

                <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1" Padding="15">
                    <Grid>
                        <TextBlock Text="Sélectionnez une commande pour voir ses détails"
                               Foreground="Gray" FontStyle="Italic"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CommandeDetails}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <DockPanel DataContext="{Binding CommandeDetails}">
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>

                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock>
                                    <Run Text="Commande n°" FontWeight="Bold"/>
                                    <Run Text="{Binding Id, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Fournisseur : " FontWeight="Bold"/>
                                    <Run Text="{Binding FournisseurNom, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Date Création : " FontWeight="Bold"/>
                                    <Run Text="{Binding DateCreation, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock>
                                    <Run Text="Statut : " FontWeight="Bold"/>
                                    <Run Text="{Binding Statut, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Date de validation : visible uniquement si renseignée -->
                                <TextBlock Visibility="{Binding DateValidation, Converter={StaticResource NullToVisibility}}">
                                    <Run Text="Validée le : " FontWeight="Bold"/>
                                    <Run Text="{Binding DateValidation, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}"/>
                                </TextBlock>

                                <!-- Date de réception : visible uniquement si renseignée -->
                                <TextBlock Visibility="{Binding DateReception, Converter={StaticResource NullToVisibility}}">
                                    <Run Text="Reçue le : " FontWeight="Bold"/>
                                    <Run Text="{Binding DateReception, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <DataGrid ItemsSource="{Binding Lignes}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Vin"        Binding="{Binding VinNom}" Width="*"/>
                                    <DataGridTextColumn Header="Qté"        Binding="{Binding Quantite}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
    </DockPanel>
</UserControl>
