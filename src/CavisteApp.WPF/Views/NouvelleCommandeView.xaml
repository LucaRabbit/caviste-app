<UserControl x:Class="CavisteApp.WPF.Views.NouvelleCommandeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="10">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Annuler" Command="{Binding AnnulerCommand}" Margin="0,0,8,0" MinWidth="100"/>
            <Button Content="Enregistrer en brouillon" Command="{Binding EnregistrerBrouillonCommand}" Margin="0,0,8,0" MinWidth="180"/>
            <Button Content="Valider (envoyer au fournisseur)" Command="{Binding ValiderCommand}" MinWidth="220"
                    Background="#2D7A2D" Foreground="White"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding MessageErreur}"
                   Foreground="Red" Margin="0,10,0,0" TextWrapping="Wrap"/>

        <StackPanel>
            <TextBlock Text="{Binding Titre}" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Fournisseur"/>
            <ComboBox ItemsSource="{Binding FournisseursDisponibles}"
                      SelectedItem="{Binding FournisseurSelectionne}"
                      DisplayMemberPath="Nom"
                      Margin="0,0,0,15"/>

            <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Ajouter un vin" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding VinsDisponibles}"
                                  SelectedItem="{Binding VinAAjouter}"
                                  DisplayMemberPath="Nom"
                                  Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding QuantiteAAjouter, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="3" Content="Ajouter" Command="{Binding AjouterLigneCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Panier" FontWeight="Bold" Margin="0,10,0,5"/>
            <DataGrid ItemsSource="{Binding Panier}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False"
                      MinHeight="150">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Vin"        Binding="{Binding Vin.Nom}" Width="*"/>
                    <DataGridTextColumn Header="Quantité"        Binding="{Binding Quantite}" Width="60"/>
                    <DataGridTemplateColumn Header="" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕"
                                        Command="{Binding DataContext.RetirerLigneCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </DockPanel>
</UserControl>