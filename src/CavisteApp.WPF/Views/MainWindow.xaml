<Window x:Class="CavisteApp.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:CavisteApp.WPF.Views.Control"
        Title="CavisteApp"
        WindowState="Normal"
        Width="1280" Height="800"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Border CornerRadius="20" Background="#DDE6ED" Padding="0">
        <DockPanel>

            <Border DockPanel.Dock="Top" Background="#27374D" Padding="10">
                <DockPanel>

                    <!-- Boutons système -->
                    <Button DockPanel.Dock="Right"
                            Content="✕"
                            Width="32" Height="32"
                            Margin="4,0,0,0"
                            Click="BtnFermer_Click"
                            ToolTip="Quitter"
                            Style="{StaticResource BoutonSysteme}"/>
                    
                    <Button DockPanel.Dock="Right"
                        Content="{Binding IconeMaximiser, RelativeSource={RelativeSource AncestorType=Window}}"
                        Width="32" Height="32"
                        Margin="0"
                        Click="BtnMaximiser_Click"
                        ToolTip="Agrandir / Restaurer"
                        Style="{StaticResource BoutonSysteme}"/>

                    <Button DockPanel.Dock="Right"
                            Content="⎯"
                            Width="32" Height="32"
                            Margin="0,0,4,0"
                            Click="BtnMinimiser_Click"
                            ToolTip="Réduire"
                            Style="{StaticResource BoutonSysteme}"/>
                    
                    <Button Content="Déconnexion"
                            DockPanel.Dock="Right"
                            Click="BtnDeconnexion_Click"
                            Padding="10,4"/>
                    
                    <TextBlock Text="{Binding MessageBienvenue}"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Right"/>
                    <StackPanel Orientation="Horizontal" Margin="20,0">
                        <Button Content="🍷Vins"
                                Command="{Binding AfficherVinsCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                        <Button Content="🍇Fournisseurs"
                                Command="{Binding AfficherFournisseursCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                        <Button Content="🤝Clients"
                                Command="{Binding AfficherClientsCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                        <Button Content="🛒Ventes"
                                Command="{Binding AfficherVentesCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                        <Button Content="📦Commandes"
                                Command="{Binding AfficherCommandesCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                        <Button Content="📥Import vins"
                                Command="{Binding AfficherImportCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid>
                <ctrl:PrintPressControl>
                    <ctrl:PrintPressControl.Style>
                        <Style TargetType="ctrl:PrintPressControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentViewModel}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ctrl:PrintPressControl.Style>
                </ctrl:PrintPressControl>
                <ContentControl Content="{Binding CurrentViewModel}" Margin="10"/>
            </Grid>

        </DockPanel>
    </Border>
</Window>