<Window x:Class="CavisteApp.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Caviste App"
        Height="600" Width="900"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <Border Background="#272537"
            CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="75"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestion de stock"
                   FontSize="22"
                   Foreground="White"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Grid.ColumnSpan="2"
                   Margin="20,0,0,0"/>
            <StackPanel Grid.Row="1">
                <RadioButton Content="Home"
                             Height="50"
                             Foreground="White"
                             FontSize="14"
                             Style="{StaticResource MenuButtonTheme}"/>
                <RadioButton Content="Vin"
             Height="50"
             Foreground="White"
             FontSize="14"
             Style="{StaticResource MenuButtonTheme}"/>
                <RadioButton Content="Stock"
             Height="50"
             Foreground="White"
             FontSize="14"
             Style="{StaticResource MenuButtonTheme}"/>
                <RadioButton Content="Fourniseur"
             Height="50"
             Foreground="White"
             FontSize="14"
             Style="{StaticResource MenuButtonTheme}"
             Visibility="{Binding IsAdmin,
                     Converter={StaticResource BooleanToVisibilityConverter}}" />

                
                <RadioButton Content="Panier"
             Height="50"
             Foreground="White"
             FontSize="14"
             Style="{StaticResource MenuButtonTheme}"/>

            </StackPanel>
            <TextBox
                Width="250"
                Height="40"
                VerticalContentAlignment="Center"
                HorizontalAlignment="Left"
                Margin="5"
                Grid.Column="1"
                Style="{StaticResource TextBox}"
                />
            <ContentControl Grid.Row="1"
                            Grid.Column="1"
                            Margin="10"/>


            <TextBox Width="250"
                     Height="40"
                     HorizontalAlignment="Left"
                     VerticalContentAlignment="Center"
                     Margin="5"
                     Grid.Column="1"
                     Style="{StaticResource TextBox}"/>


            <Button Content="Déconnexion"
                        HorizontalAlignment="Left"
                        Padding="10,5"
                        Click="BtnDeconnexion_Click" Margin="577,0,0,0" Grid.Column="1"
                    />

        </Grid>
    </Border>
</Window>