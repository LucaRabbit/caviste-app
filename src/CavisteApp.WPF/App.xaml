<Application x:Class="CavisteApp.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CavisteApp.WPF.ViewModels"
             xmlns:vw="clr-namespace:CavisteApp.WPF.Views"
             xmlns:conv="clr-namespace:CavisteApp.WPF.Converters">
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        
            <DataTemplate DataType="{x:Type vm:VinsViewModel}">
                <vw:VinsView/>
            </DataTemplate>
            <!-- Ajoute ici les futurs mappings :
            <DataTemplate DataType="{x:Type vm:ClientsViewModel}">
                <vw:ClientsView/>
            </DataTemplate>
            -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
